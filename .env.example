APP_NAME=Nexum
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Base de datos (PostgreSQL requerido) ──────────────────────
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=nexum_db
DB_USERNAME=postgres
DB_PASSWORD=

# ─── Drivers de infraestructura (sin Redis) ────────────────────
SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
CACHE_PREFIX=

# ─── Correo electrónico ────────────────────────────────────────
# Para desarrollo local podés usar MAIL_MAILER=log (escribe en storage/logs)
# o configurar Mailtrap: https://mailtrap.io
MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@nexum.app"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

# ─── URLs del sistema ──────────────────────────────────────────
# El link de reset de contraseña apunta a:
# {FRONTEND_URL}/reset-password?token=...&email=...
FRONTEND_URL=http://localhost:5173

# ─── Credenciales del seeder ───────────────────────────────────
# Contraseña del usuario admin@portfolio.test (creado por AdminUserSeeder)
ADMIN_PASSWORD=
