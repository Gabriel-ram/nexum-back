              "path": ["api","v1","admin","users"],
              "query": [
                { "key": "is_active", "value": "true",  "description": "true | false | omitir para todos" },
                { "key": "per_page",  "value": "20",    "description": "Máx 100, default 20" }
              ]
            }
          }
