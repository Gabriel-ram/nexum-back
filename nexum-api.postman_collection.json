    {
      "name": "Admin — Usuarios",
      "description": "Gestión de usuarios. Requiere Bearer {{admin_token}} (login con admin@portfolio.test).",
      "item": [
        {
          "name": "Listar Usuarios",
          "request": {
            "method": "GET",
